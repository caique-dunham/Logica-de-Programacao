Números de Bilhetes e informações

package aula3;
import java.util.Scanner;
public class aulatres {
	public static void main(String[] args) {
		Scanner entrada=new Scanner(System.in);
		int bilhete;
		System.out.println("Numero de Bilhetes:");
		bilhete=entrada.nextInt();
		if(bilhete==1){
		System.out.print("Bilhete Unitario:2 Reais");	
		}else if(bilhete==2){
		System.out.print("Bilhete Duplo:3 reais");	
		}else if(bilhete==10){
		System.out.print("Bilhete de 10 viagens ou mais:12 reais");	
		}else {
		System.out.print("Nao sei imformar!");	
		}
}
}
