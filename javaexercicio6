TOTAL DE TEMPO EM SEGUNDOS
package aula2;
import java.util.Scanner;
public class auladois {
	public static void main(String[] args) {
		Scanner entrada=new Scanner(System.in);
		String usuario;
		usuario="Caique";
		System.out.println("Nome do usuario:"+usuario);
		double horas,min,seg,total;
		System.out.println("Horas:");
		horas=entrada.nextDouble()*3600;
		System.out.println("Minutos:");
		min=entrada.nextDouble()*60;
		System.out.println("Segundos:");
		seg=entrada.nextDouble();
		entrada.close();
		total=horas+min+seg;
		System.out.println("Usuario:"+usuario);
		System.out.print("Total de tempo em segundos:" + total);		
	}
}
