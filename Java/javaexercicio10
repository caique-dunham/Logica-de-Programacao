Dois valores inteiros A e B se os valores forem iguais deverá
se somar os dois,caso contrário multiplique A por B.

package aula3;
import java.util.Scanner;
public class aulatres {
	public static void main(String[] args) {
		Scanner entrada=new Scanner (System.in);
		int numA,numB;
		System.out.println("numA:");
		numA=entrada.nextInt();
		System.out.println("numB");
		numB=entrada.nextInt();
		if (numA==numB) {
			System.out.println("Soma:"+ (numA+numB));
		} else {
			System.out.print("Produto"+numA*numB);
	 }
}
}
